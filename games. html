<!DOCTYPE html>
<html>
<head>
<title>GOATED Games</title>

<style>

body{
background:black;
color:white;
font-family:Arial;
text-align:center;
}

h1{
color:gold;
font-size:50px;
margin-top:20px;
}

a{
color:gold;
text-decoration:none;
font-size:18px;
}

iframe{
width:900px;
height:500px;
border:3px solid gold;
border-radius:10px;
margin-top:20px;
}

.games{
margin-top:30px;
}

button{
background:gold;
color:black;
border:none;
padding:10px 15px;
margin:5px;
font-weight:bold;
cursor:pointer;
border-radius:5px;
}

button:hover{
background:white;
}

</style>

</head>

<body>

<h1>👑 GOATED</h1>

<a href="index.html">⬅ Back</a>

<br>

<iframe id="gameFrame"></iframe>

<div class="games">

<button onclick="loadGame('https://ubg100.github.io/run/')">Run</button>
<button onclick="loadGame('https://ubg100.github.io/run-3/')">Run 3</button>
<button onclick="loadGame('https://ubg100.github.io/slope/')">Slope</button>
<button onclick="loadGame('https://ubg100.github.io/2048/')">2048</button>
<button onclick="loadGame('https://ubg100.github.io/drift-boss/')">Drift Boss</button>
<button onclick="loadGame('https://ubg100.github.io/moto-x3m/')">Moto X3M</button>
